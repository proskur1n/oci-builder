{
	"name": "oci-builder",
	"version": "0.0.1",
	"description": "Build Node.js container images without docker",
	"author": "Andrey Proskurin <andreyproskurin@protonmail.com>",
	"license": "MIT",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/proskur1n/oci-builder.git"
	},
	"homepage": "https://github.com/proskur1n/oci-builder",
	"keywords": [
		"oci",
		"container",
		"image",
		"builder",
		"docker",
		"registry",
		"jib",
		"ko"
	],
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"clean": "rm -fr dist",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc",
		"verify": "npm run typecheck && npm run test",
		"prepublishOnly": "npm run verify"
	},
	"dependencies": {
		"modern-tar": "^0.7.6"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"prettier": "^3.8.3",
		"tsx": "^4.21.0",
		"typescript": "^5.7.3",
		"vitest": "^3.0.2"
	},
	"engines": {
		"node": "^20.0.0 || >=22.0.0"
	}
}
